---
import type { CollectionEntry } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Main from "@layouts/Main.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import Pagination from "@components/Pagination.astro";
import Card from "@components/Card";
import { SITE } from "@config";

export interface Props {
  currentPage: number;
  totalPages: number;
  paginatedPosts: CollectionEntry<"blog">[];
}

const { currentPage, totalPages, paginatedPosts } = Astro.props;

// All paginated pages canonicalize back to /posts/ (page 1) to consolidate authority.
const canonicalURL = new URL("/posts/", Astro.site).href;

// Build rel=prev / rel=next URLs for pagination hints.
const prevUrl =
  currentPage > 1
    ? new URL(
        currentPage - 1 === 1 ? "/posts/" : `/posts/${currentPage - 1}/`,
        Astro.site
      ).href
    : null;
const nextUrl =
  currentPage < totalPages
    ? new URL(`/posts/${currentPage + 1}/`, Astro.site).href
    : null;
---

<Layout title={`Posts | ${SITE.title}`} canonicalURL={canonicalURL}>
  {prevUrl && <link rel="prev" href={prevUrl} slot="head" />}
  {nextUrl && <link rel="next" href={nextUrl} slot="head" />}
  <Header activeNav="posts" />
  <Main pageTitle="Posts" pageDesc="All the articles I've posted.">
    <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mt-8">
      {
        paginatedPosts.map(({ data, slug, body }) => {
          const wordCount = body.split(/\s+/).length;
          const readingTime = `${Math.ceil(wordCount / 200)} MIN READ`;
          return (
            <Card
              href={`/posts/${slug}/`}
              frontmatter={data}
              readingTime={readingTime}
              tags={data.tags}
            />
          );
        })
      }
    </ul>
  </Main>

  <Pagination
    {currentPage}
    {totalPages}
    prevUrl={`/posts${currentPage - 1 !== 1 ? "/" + (currentPage - 1) : ""}/`}
    nextUrl={`/posts/${currentPage + 1}/`}
  />

  <Footer noMarginTop={totalPages > 1} />
</Layout>
