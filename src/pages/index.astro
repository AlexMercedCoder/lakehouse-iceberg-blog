---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import getSortedPosts from "@utils/getSortedPosts";
import { SITE, SOCIALS } from "@config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const socialCount = SOCIALS.filter(social => social.active).length;

const mustReads = [
  {
    title: "The Definitive Guide to the Semantic Layer",
    description:
      "Understand what a semantic layer is, why it matters for modern data architectures, and how it creates a consistent, governed layer between raw data and business consumers.",
    href: "https://www.dremio.com/blog/semantic-layer-the-definitive-guide/",
  },
  {
    title: "Apache Polaris: The Catalog Standard for Lakehouses and AI",
    description:
      "A deep dive into Apache Polaris, the open-source catalog that is emerging as the standard for managing Iceberg tables across multi-engine Lakehouses and AI workloads.",
    href: "https://www.dremio.com/blog/apache-polaris-the-catalog-standard-for-lakehouses-and-ai/",
  },
  {
    title: "What Are Table Formats and Why Were They Needed?",
    description:
      "Explore the history and motivations behind open table formats like Apache Iceberg, Delta Lake, and Apache Hudi, and why they solved critical problems in big data engineering.",
    href: "https://www.dremio.com/blog/what-are-table-formats-and-why-were-they-needed/",
  },
  {
    title: "What is Dremio?",
    description:
      "A comprehensive overview of Dremio's Lakehouse platform — how it unifies data access, accelerates queries, and powers self-service analytics across cloud and on-premise sources.",
    href: "https://www.dremio.com/blog/what-is-dremio/",
  },
  {
    title: "What Apache Iceberg Native Actually Means",
    description:
      "Not all Iceberg integrations are equal. This article breaks down what it truly means for a platform to be 'Apache Iceberg native' and why the distinction matters for your architecture.",
    href: "https://www.dremio.com/blog/what-apache-iceberg-native-actually-means/",
  },
  {
    title: "Open Source and the Data Lakehouse",
    description:
      "A survey of the open source ecosystem powering modern Data Lakehouses — from Apache Iceberg and Nessie to Apache Arrow and Spark — and how they work together.",
    href: "https://www.dremio.com/blog/open-source-and-the-data-lakehouse/",
  },
  {
    title: "What is Agentic Analytics?",
    description:
      "Discover how AI agents are transforming analytics pipelines — autonomously querying data, generating insights, and taking actions — and what it means for the future of the Lakehouse.",
    href: "https://www.dremio.com/blog/what-is-agentic-analytics/",
  },
];
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <h1>Welcome!</h1>
      <a
        target="_blank"
        href="/rss.xml"
        class="rss-link"
        aria-label="rss feed"
        title="RSS Feed"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="rss-icon"
          ><path
            d="M19 20.001C19 11.729 12.271 5 4 5v2c7.168 0 13 5.832 13 13.001h2z"
          ></path><path
            d="M12 20.001h2C14 14.486 9.514 10 4 10v2c4.411 0 8 3.589 8 8.001z"
          ></path><circle cx="6" cy="18" r="2"></circle>
        </svg>
        <span class="sr-only">RSS Feed</span>
      </a>

      <p>
        This blog contains articles about the Apache Iceberg Data Lakehouse
        (using your data lake as your data warehouse) and the Agentic Lakehouse
        (lakehouses optimized for AI agents). If you are looking to understand
        what Apache Iceberg is, how a data lakehouse works, or where to find
        deep-dive resources, you will find all of that content right here.
      </p>
      <p>
        <b>
          This blog is not affiliated with the Apache Foundation or the Apache
          Iceberg project whose official page is iceberg.apache.org.
        </b>
      </p>
      <p>
        Join the Data Lakehouse Hub Slack Community:
        <LinkButton
          className="underline decoration-dashed underline-offset-4 hover:text-skin-accent"
          href="https://bit.ly/lakehouse-hub-slack"
        >
          Join Now!
        </LinkButton>
      </p>

      <p>
        Subscribe to our calendar of Data Lakehouse events:
        <LinkButton
          className="underline decoration-dashed underline-offset-4 hover:text-skin-accent"
          href="https://lu.ma/Lakehouselinkups"
        >
          Subscribe!
        </LinkButton>
      </p>
      {
        // only display if at least one social link is enabled
        socialCount > 0 && (
          <div class="social-wrapper">
            <div class="social-links">Social Links:</div>
            <Socials />
          </div>
        )
      }
    </section>

    <Hr />

    {
      featuredPosts.length > 0 && (
        <>
          <section id="featured">
            <h2>Featured</h2>
            <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mt-6">
              {featuredPosts.map(({ data, slug, body }) => {
                const wordCount = body.split(/\s+/).length;
                const readingTime = `${Math.ceil(wordCount / 200)} MIN READ`;
                return (
                  <Card
                    href={`/posts/${slug}/`}
                    frontmatter={data}
                    secHeading={false}
                    readingTime={readingTime}
                    tags={data.tags}
                  />
                );
              })}
            </ul>
          </section>
          {recentPosts.length > 0 && <Hr />}
        </>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts">
          <h2>Recent Posts</h2>
          <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mt-6">
            {recentPosts.map(
              ({ data, slug, body }, index) =>
                index < SITE.postPerIndex && (
                  <Card
                    href={`/posts/${slug}/`}
                    frontmatter={data}
                    secHeading={false}
                    readingTime={`${Math.ceil(body.split(/\s+/).length / 200)} MIN READ`}
                    tags={data.tags}
                  />
                )
            )}
          </ul>
        </section>
      )
    }

    <div class="all-posts-btn-wrapper">
      <LinkButton href="/posts/">
        All Posts
        <svg xmlns="http://www.w3.org/2000/svg"
          ><path
            d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z"
          ></path>
        </svg>
      </LinkButton>
    </div>

    <Hr />

    <section id="must-reads">
      <h2>
        Must Reads on Iceberg, Agentic AI and Lakehouse from Around the Web
      </h2>
      <ul class="must-reads-grid">
        {
          mustReads.map(({ title, description, href }) => (
            <li class="must-read-card">
              <h3 class="must-read-title">{title}</h3>
              <p class="must-read-desc">{description}</p>
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                class="must-read-btn"
              >
                Read Article
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z" />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* ===== Hero Section ===== */
  #hero {
    @apply pb-6 pt-8;
  }
  #hero h1 {
    @apply my-4 inline-block text-3xl font-bold sm:my-8 sm:text-5xl;
  }
  #hero .rss-link {
    @apply mb-6;
  }
  #hero .rss-icon {
    @apply mb-2 h-6 w-6 scale-110 fill-skin-accent sm:mb-3 sm:scale-125;
  }
  #hero p {
    @apply my-2;
  }
  .social-wrapper {
    @apply mt-4 flex flex-col sm:flex-row sm:items-center;
  }
  .social-links {
    @apply mb-1 mr-2 whitespace-nowrap sm:mb-0;
  }

  /* ===== Featured & Recent Posts Sections ===== */
  #featured,
  #recent-posts {
    @apply pb-6 pt-12;
  }
  #featured h2,
  #recent-posts h2 {
    @apply text-2xl font-semibold tracking-wide;
  }
  .all-posts-btn-wrapper {
    @apply my-8 text-center;
  }

  /* ===== Must Reads Section ===== */
  #must-reads {
    @apply pb-10 pt-12;
  }
  #must-reads h2 {
    @apply mb-6 text-2xl font-semibold tracking-wide;
  }
  .must-reads-grid {
    @apply grid gap-5 sm:grid-cols-2;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .must-read-card {
    @apply flex flex-col rounded-lg border border-skin-line bg-skin-card p-5;
    transition: box-shadow 0.2s ease;
  }
  .must-read-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }
  .must-read-title {
    @apply mb-2 text-base font-semibold leading-snug text-skin-accent;
  }
  .must-read-desc {
    @apply mb-4 flex-1 text-sm leading-relaxed opacity-80;
  }
  .must-read-btn {
    @apply inline-flex items-center gap-1 self-start rounded border border-skin-accent px-3 py-1.5 text-xs font-semibold text-skin-accent transition-colors hover:bg-skin-accent hover:text-skin-inverted;
  }
</style>
