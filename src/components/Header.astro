---
import { LOGO_IMAGE, SITE } from "@config";
import LinkButton from "./LinkButton.astro";

export interface Props {
  activeNav?:
    | "posts"
    | "tags"
    | "about"
    | "search"
    | "iceberg"
    | "lakehouse"
    | "iceberg-guide"
    | "agentic";
}

const { activeNav } = Astro.props;
const isContentActive = [
  "posts",
  "lakehouse",
  "iceberg-guide",
  "agentic",
  "iceberg",
  "tags",
].includes(activeNav || "");
---

<header
  class="sticky top-0 z-40 w-full border-b border-skin-line bg-skin-fill/85 backdrop-blur-md"
>
  <a id="skip-to-content" href="#main-content">Skip to content</a>
  <div class="nav-container">
    <div class="top-nav-wrap">
      <a
        href="/"
        class="logo font-extrabold tracking-tight text-skin-base whitespace-nowrap hover:text-skin-accent transition-colors"
      >
        {
          LOGO_IMAGE.enable ? (
            <img
              src={`/assets/${LOGO_IMAGE.svg ? "logo.svg" : "logo.png"}`}
              alt={SITE.title}
              width={LOGO_IMAGE.width}
              height={LOGO_IMAGE.height}
            />
          ) : (
            SITE.title
          )
        }
      </a>

      <button
        class="hamburger-menu focus-outline sm:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="nav-menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="menu-icon"
        >
          <line x1="7" y1="12" x2="21" y2="12" class="line"></line>
          <line x1="3" y1="6" x2="21" y2="6" class="line"></line>
          <line x1="12" y1="18" x2="21" y2="18" class="line"></line>
          <line x1="18" y1="6" x2="6" y2="18" class="close"></line>
          <line x1="6" y1="6" x2="18" y2="18" class="close"></line>
        </svg>
      </button>
    </div>

    <nav
      id="nav-menu"
      class="display-none sm:flex w-full sm:w-auto flex-col sm:flex-row items-center justify-between gap-4 pb-4 sm:pb-0"
    >
      <ul
        id="menu-items"
        class="flex flex-col sm:flex-row nav-links gap-y-3 sm:gap-x-6 w-full sm:w-auto items-center"
      >
        <!-- Content Sub-menu -->
        <li>
          <details class="dropdown relative group">
            <summary
              class={`flex items-center gap-1.5 px-2 py-1 text-sm font-medium hover:text-skin-accent sm:text-base cursor-pointer list-none focus-outline select-none ${isContentActive ? "active" : ""}`}
            >
              <span>Content</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="chevron transition-transform duration-200 group-open:rotate-180"
              >
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </summary>
            <div
              class="dropdown-menu absolute left-1/2 -translate-x-1/2 sm:left-0 sm:translate-x-0 mt-2 bg-skin-card border border-skin-line rounded-lg shadow-lg py-2 min-w-[220px] z-50"
            >
              <a
                href="/posts/"
                class={`block px-4 py-2 text-sm hover:bg-skin-card-muted/50 ${activeNav === "posts" ? "text-skin-accent font-semibold" : "text-skin-base"}`}
                >Posts</a
              >
              <a
                href="/data-lakehouse/"
                class={`block px-4 py-2 text-sm hover:bg-skin-card-muted/50 ${activeNav === "lakehouse" ? "text-skin-accent font-semibold" : "text-skin-base"}`}
                >Lakehouse</a
              >
              <a
                href="/apache-iceberg/"
                class={`block px-4 py-2 text-sm hover:bg-skin-card-muted/50 ${activeNav === "iceberg-guide" ? "text-skin-accent font-semibold" : "text-skin-base"}`}
                >Iceberg Guide</a
              >
              <a
                href="/agentic-lakehouse/"
                class={`block px-4 py-2 text-sm hover:bg-skin-card-muted/50 ${activeNav === "agentic" ? "text-skin-accent font-semibold" : "text-skin-base"}`}
                >Agentic AI</a
              >
              <a
                href="/iceberg/"
                class={`block px-4 py-2 text-sm hover:bg-skin-card-muted/50 ${activeNav === "iceberg" ? "text-skin-accent font-semibold" : "text-skin-base"}`}
                >Iceberg Knowledge Base</a
              >
              <a
                href="/tags/"
                class={`block px-4 py-2 text-sm hover:bg-skin-card-muted/50 ${activeNav === "tags" ? "text-skin-accent font-semibold" : "text-skin-base"}`}
                >Tags</a
              >
            </div>
          </details>
        </li>
        <li>
          <a href="/about/" class={activeNav === "about" ? "active" : ""}
            >About</a
          >
        </li>
        <li>
          <a
            href="/search/"
            class={`flex items-center gap-1.5 px-2 py-1 text-sm font-medium hover:text-skin-accent sm:text-base transition-colors duration-150 focus-outline ${activeNav === "search" ? "active text-skin-accent" : "text-skin-base"}`}
            aria-label="Search"
            title="Search"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="scale-110 sm:scale-100"
            >
              <path
                d="M19.023 16.977a35.13 35.13 0 0 1-1.367-1.384c-.372-.378-.596-.653-.596-.653l-2.8-1.337A6.962 6.962 0 0 0 16 9c0-3.859-3.14-7-7-7S2 5.141 2 9s3.14 7 7 7c1.763 0 3.37-.66 4.603-1.739l1.337 2.8s.275.224.653.596c.387.363.896.854 1.384 1.367l1.358 1.392.604.646 2.121-2.121-.646-.604c-.379-.372-.885-.866-1.391-1.36zM9 14c-2.757 0-5-2.243-5-5s2.243-5 5-5 5 2.243 5 5-2.243 5-5 5z"
              ></path>
            </svg>
            <span class="sm:hidden">Search</span>
          </a>
        </li>
        {
          SITE.lightAndDarkMode && (
            <li>
              <button
                id="theme-btn"
                class="flex items-center gap-1.5 px-2 py-1 text-sm font-medium hover:text-skin-accent sm:text-base transition-colors duration-150 focus-outline text-skin-base"
                title="Toggles light & dark"
                aria-label="auto"
                aria-live="polite"
              >
                <svg xmlns="http://www.w3.org/2000/svg" id="moon-svg">
                  <path d="M20.742 13.045a8.088 8.088 0 0 1-2.077.271c-2.135 0-4.14-.83-5.646-2.336a8.025 8.025 0 0 1-2.064-7.723A1 1 0 0 0 9.73 2.034a10.014 10.014 0 0 0-4.489 2.582c-3.898 3.898-3.898 10.243 0 14.143a9.937 9.937 0 0 0 7.072 2.93 9.93 0 0 0 7.07-2.929 10.007 10.007 0 0 0 2.583-4.491 1.001 1.001 0 0 0-1.224-1.224zm-2.772 4.301a7.947 7.947 0 0 1-5.656 2.343 7.953 7.953 0 0 1-5.658-2.344c-3.118-3.119-3.118-8.195 0-11.314a7.923 7.923 0 0 1 2.06-1.483 10.027 10.027 0 0 0 2.89 7.848 9.972 9.972 0 0 0 7.848 2.891 8.036 8.036 0 0 1-1.484 2.059z" />
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" id="sun-svg">
                  <path d="M6.993 12c0 2.761 2.246 5.007 5.007 5.007s5.007-2.246 5.007-5.007S14.761 6.993 12 6.993 6.993 9.239 6.993 12zM12 8.993c1.658 0 3.007 1.349 3.007 3.007S13.658 15.007 12 15.007 8.993 13.658 8.993 12 10.342 8.993 12 8.993zM10.998 19h2v3h-2zm0-17h2v3h-2zm-9 9h3v2h-3zm17 0h3v2h-3zM4.219 18.363l2.12-2.122 1.415 1.414-2.12 2.122zM16.24 6.344l2.122-2.122 1.414 1.414-2.122 2.122zM6.342 7.759 4.22 5.637l1.415-1.414 2.12 2.122zm13.434 10.605-1.414 1.414-2.122-2.122 1.414-1.414z" />
                </svg>
                <span class="sm:hidden">Light/Dark Mode</span>
              </button>
            </li>
          )
        }
        <li>
          <a
            href="https://lu.ma/Lakehouselinkups"
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full bg-[#002b49] text-[#f7f9fb] dark:bg-[#f7f9fb] dark:text-[#002b49] px-4 py-1.5 text-xs font-semibold hover:opacity-90 transition-opacity whitespace-nowrap"
          >
            Subscribe
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  #skip-to-content {
    @apply absolute -top-full left-16 z-50 bg-skin-accent px-3 py-2 text-skin-inverted transition-all focus:top-4;
  }
  .nav-container {
    @apply mx-auto flex max-w-5xl flex-col justify-between p-4 sm:flex-row sm:items-center sm:h-16;
  }
  .top-nav-wrap {
    @apply flex w-full items-center justify-between sm:w-auto;
  }
  .logo {
    @apply py-1 text-xl font-extrabold sm:text-2xl;
  }
  .hamburger-menu {
    @apply p-2;
  }
  .hamburger-menu svg {
    @apply h-6 w-6 fill-skin-base;
  }

  nav {
    @apply flex items-center gap-4;
  }
  .nav-actions {
    @apply flex items-center gap-2;
  }

  .nav-links {
    @apply flex w-full flex-col sm:flex-row items-center justify-center gap-y-3 pb-3 sm:pb-0;
  }
  .nav-links li {
    @apply flex items-center;
  }
  .nav-links li a {
    @apply px-2 py-1 text-sm font-medium hover:text-skin-accent sm:text-base transition-colors duration-150;
  }
  .nav-links li a.active {
    @apply text-skin-base border-b-2 border-skin-accent pb-[2px] sm:pb-[4px];
  }

  /* Dropdown Styles */
  details.dropdown summary::-webkit-details-marker {
    display: none;
  }

  details.dropdown summary.active {
    @apply text-skin-base border-b-2 border-skin-accent pb-[2px] sm:pb-[4px];
  }

  /* Open chevron rotation */
  details[open] summary .chevron {
    transform: rotate(180deg);
  }

  /* Mobile: toggle menu */
  #nav-menu.display-none {
    display: none;
  }
  @media (min-width: 640px) {
    #nav-menu.display-none {
      display: flex;
    }
  }

  #theme-btn svg {
    @apply scale-110 hover:rotate-12 sm:scale-100;
  }

  .menu-icon line {
    @apply transition-opacity duration-75 ease-in-out;
  }
  .menu-icon .close {
    opacity: 0;
  }
  .menu-icon.is-active .line {
    @apply opacity-0;
  }
  .menu-icon.is-active .close {
    @apply opacity-100;
  }
</style>

<script>
  function setupNav() {
    const menuBtn = document.querySelector(".hamburger-menu");
    const menuIcon = document.querySelector(".menu-icon");
    const navMenu = document.querySelector("#nav-menu");

    menuBtn?.addEventListener("click", () => {
      const menuExpanded = menuBtn.getAttribute("aria-expanded") === "true";
      menuIcon?.classList.toggle("is-active");
      menuBtn.setAttribute("aria-expanded", menuExpanded ? "false" : "true");
      menuBtn.setAttribute(
        "aria-label",
        menuExpanded ? "Open Menu" : "Close Menu"
      );
      navMenu?.classList.toggle("display-none");
    });

    // Close details dropdown when clicking outside
    document.addEventListener("click", event => {
      const dropdowns = document.querySelectorAll("details.dropdown");
      dropdowns.forEach(dropdown => {
        if (!dropdown.contains(event.target as Node)) {
          dropdown.removeAttribute("open");
        }
      });
    });
  }

  setupNav();
  document.addEventListener("astro:after-swap", setupNav);
</script>
